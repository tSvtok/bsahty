@startuml

skinparam classAttributeIconSize 0
skinparam roundcorner 12
skinparam class {
    BackgroundColor White
    BorderColor black
}

enum Role {
  USER
  ADMIN
}

enum Level {
  BEGINNER
  INTERMEDIATE
  PRO
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}

enum EventStatus {
  OPEN
  FULL
  CLOSED
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum ReactionType {
  LIKE
  DISLIKE
}

enum Sport {
  FOOTBALL
  TENNIS
  BASKETBALL
  RUNNING
  YOGA
  CYCLING
  SWIMMING
  OTHER
}

class User {
  +id: int
  +name: string
  +email: string
  +bio: text
  +location: string
  +city: string
  +avatar: string
  +sports: Sport[]
  +is_banned: boolean
  +role: Role
  +level: Level
  +created_at: datetime
}

class Spot {
  +id: int
  +name: string
  +type: string
  +address: string
  +city: string
  +status: Status
  +image: string
  +created_at: datetime
}

class Event {
  +id: int
  +title: string
  +sport: Sport
  +date: datetime
  +location: string
  +max_participants: int
  +status: EventStatus
  +organizer_id: int
  +spot_id: int
  +created_at: datetime
}

class Question {
  +id: int
  +title: string
  +content: text
  +image: string
  +sport: Sport
  +user_id: int
  +spot_id: int
  +event_id: int
  +created_at: datetime
}

class Comment {
  +id: int
  +content: text
  +user_id: int
  +question_id: int
  +created_at: datetime
}

class Reaction {
  +id: int
  +type: ReactionType
  +user_id: int
  +target_id: int
  +target_type: string
  +created_at: datetime
}

class Friendship {
  +id: int
  +user_id: int (requester)
  +friend_id: int (receiver)
  +status: FriendshipStatus
  +created_at: datetime
}

class Conversation {
  +id: int
  +created_at: datetime
}

class Message {
  +id: int
  +content: text
  +is_read: boolean
  +user_id: int
  +conversation_id: int
  +created_at: datetime
}

class Notification {
  +id: int
  +type: string
  +data: json
  +read_at: datetime
  +user_id: int
}

User "1" -- "0..*" Question : writes
User "1" -- "0..*" Comment : comments
User "1" -- "0..*" Message : sends
User "1" -- "0..*" Friendship : requester -> receiver
User "1" -- "0..*" Event : organizes
User "1" -- "0..*" Spot : creates

Event "0..*" -- "0..1" Spot : hosted_at
Event "*" -- "*" User : participates

Question "1" -- "0..*" Comment : has
Comment "1" -- "0..*" Reaction : receives

Conversation "1" -- "0..*" Message : contains

User "*" -- "0..*" Conversation : participates


Reaction "*" -- "1" Question : targets


@enduml